# Where Hugging Face caches model weights; keep this outside the project tree.
HF_HOME=/path/to/hf-cache
# Target model served by the engine (GPT-2 family).
IE_MODEL=gpt2
# Draft model for speculative decoding; leave empty to disable.
IE_DRAFT_MODEL=distilgpt2
# Tokens per KV cache block.
IE_BLOCK_SIZE=16
# Total KV cache blocks (block_size * num_blocks = max cached tokens).
IE_NUM_BLOCKS=512
# Maximum sequences decoded together in one batch.
IE_MAX_BATCH_SIZE=8
# Hard cap on prompt + generated tokens per request (GPT-2 limit is 1024).
IE_MAX_MODEL_LEN=1024
# Draft tokens proposed per speculative round.
IE_NUM_SPECULATIVE_TOKENS=4
# Server bind address.
IE_HOST=127.0.0.1
# Server port.
IE_PORT=8000
